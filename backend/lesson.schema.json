{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lesson Schema",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["units"],
    "properties": {
      "units": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name", "lessons"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "lessons": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}